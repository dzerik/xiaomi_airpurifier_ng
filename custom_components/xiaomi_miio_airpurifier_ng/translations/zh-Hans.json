  "config": {
    "step": {
      "user": {
        "title": "配置小米空气净化器",
        "description": "输入小米设备的连接信息。",
        "data": {
          "host": "主机地址",
          "token": "Token",
          "name": "名称（可选）",
          "model": "型号（可选，自动检测）"
        },
        "data_description": {
          "host": "小米设备的 IP 地址或主机名。",
          "token": "用于设备认证的 32 位字符 token。您可以通过文档中描述的多种方法获取。",
          "name": "设备的友好名称。",
          "model": "设备型号。留空以自动检测。"
        }
      },
      "reconfigure": {
        "title": "重新配置小米空气净化器",
        "description": "更新小米设备的连接信息。",
        "data": {
          "host": "主机地址",
          "token": "Token",
          "model": "型号"
        }
      },
      "reauth_confirm": {
        "title": "重新认证小米空气净化器",
        "description": "{host} 的 token 已失效。请输入新的 token。",
        "data": {
          "token": "Token"
        },
        "data_description": {
          "token": "用于设备认证的新 32 位字符 token。"
        }
      }
    },
    "error": {
      "cannot_connect": "无法连接到设备。请检查主机地址和 token。",
      "unknown": "发生了意外错误。"
    },
    "abort": {
      "already_configured": "该设备已配置。",
      "reconfigure_successful": "配置已成功更新。",
      "reauth_successful": "重新认证成功。"
    }
